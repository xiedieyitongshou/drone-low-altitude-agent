# Copy this file to .env before running docker compose.

# Application
APP_NAME=drone-low-altitude-agent
APP_ENV=docker
APP_PORT=8000
LOG_LEVEL=INFO

# Weather API
QWEATHER_API_KEY=your_qweather_api_key
QWEATHER_GEO_BASE_URL=https://your-qweather-host
QWEATHER_WEATHER_BASE_URL=https://your-qweather-host
QWEATHER_WARNING_BASE_URL=https://your-qweather-host
QWEATHER_TIMEOUT_SECONDS=10
QWEATHER_MAX_RETRIES=3
QWEATHER_RETRY_BACKOFF_SECONDS=1
QWEATHER_LANG=zh

# Storage
DATABASE_URL=sqlite:///./data/drone_agent.db

# Session memory
SESSION_MEMORY_BACKEND=redis
REDIS_URL=redis://redis:6379/0
SESSION_MEMORY_TTL_SECONDS=1800
SESSION_MEMORY_REDIS_KEY_PREFIX=drone_agent:session:

# LLM explanation and future parser fallback
LLM_ENABLED=false
LLM_PROVIDER=none
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=600
