# Application
APP_NAME=drone-low-altitude-agent
APP_ENV=local
APP_PORT=8000

# Weather API
QWEATHER_API_KEY=your_qweather_api_key
QWEATHER_GEO_BASE_URL=https://geoapi.qweather.com
QWEATHER_WEATHER_BASE_URL=https://devapi.qweather.com
QWEATHER_WARNING_BASE_URL=https://devapi.qweather.com
QWEATHER_TIMEOUT_SECONDS=10
QWEATHER_MAX_RETRIES=3
QWEATHER_RETRY_BACKOFF_SECONDS=1
QWEATHER_LANG=zh

# Storage
DATABASE_URL=postgresql://user:password@localhost:5432/drone_agent
REDIS_URL=redis://localhost:6379/0
